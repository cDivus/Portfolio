---
import Layout from '../layouts/Layout.astro';

const GIST_URL = "https://gist.githubusercontent.com/cDivus/e2d057f5fefe33c77a108c0b8ddc5df1/raw/portfolio.json";

const res = await fetch(GIST_URL);
if (!res.ok) {
  throw new Error(`Failed to fetch portfolio data: ${res.status} ${res.statusText}`);
}
const data = await res.json();

function parseMarkdown(text: string) {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.*?)\*/g, '<em>$1</em>')
    .replace(/_(.*?)_/g, '<em>$1</em>');
}
---

<Layout title="Reymel Sardenia - cDivus" description="cDivus - Portfolio of a Full-Stack Software Engineer & Creative Developer. Exploring projects and skills.">
    <main class="max-w-[880px] mx-auto px-6 py-8">
        <!-- Hero Section -->
        <section id="home" class="py-4 md:py-8">
            <div class="flex flex-col md:flex-row gap-12 items-start md:items-center mb-7">
                <div class="relative flex-shrink-0 group">
                    <div class="absolute -inset-1 rounded-full bg-gradient-to-br from-primary to-border-color -z-10 transition-transform duration-300 group-hover:scale-[1.02]"></div>
                    <img src="/assets/cdivus_avatar.jpg" alt="Reymel Sardenia" class="w-[130px] md:w-[190px] h-[130px] md:h-[190px] rounded-full object-cover border-4 border-white shadow-lg transition-transform duration-300 group-hover:scale-[1.02]">
                </div>
                <div class="flex flex-col gap-3">
                    <h1 id="profile-name" class="font-heading text-4xl md:text-5xl font-extrabold tracking-tight leading-none text-text-primary">
                        {data.profile.name}
                    </h1>
                    <p id="profile-role" class="text-lg font-medium text-text-secondary">
                        {data.profile.role}
                    </p>
                    <div class="flex gap-3 mt-2 flex-wrap">
                        {data.profile.email && (
                            <a href={`mailto:${data.profile.email}`} class="w-11 h-11 rounded-full bg-white border border-border-color shadow-sm flex items-center justify-center transition-all duration-300 hover:-translate-y-[3px] hover:shadow-md hover:bg-bg-secondary hover:border-text-muted group" aria-label="Email" title="Email">
                                <img src="/assets/icons/email.svg" alt="Email" class="w-5 h-5 transition-colors filter invert-[32%] sepia-[10%] saturate-[1210%] hue-rotate-[175deg] brightness-[97%] contrast-[87%]">
                            </a>
                        )}
                        {data.profile.github && (
                            <a href={data.profile.github} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-white border border-border-color shadow-sm flex items-center justify-center transition-all duration-300 hover:-translate-y-[3px] hover:shadow-md hover:bg-bg-secondary hover:border-text-muted group" aria-label="GitHub" title="GitHub">
                                <img src="/assets/icons/github.svg" alt="GitHub" class="w-5 h-5 transition-colors filter invert-[32%] sepia-[10%] saturate-[1210%] hue-rotate-[175deg] brightness-[97%] contrast-[87%]">
                            </a>
                        )}
                        {data.profile.linkedin && (
                            <a href={data.profile.linkedin} target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-white border border-border-color shadow-sm flex items-center justify-center transition-all duration-300 hover:-translate-y-[3px] hover:shadow-md hover:bg-bg-secondary hover:border-text-muted group" aria-label="LinkedIn" title="LinkedIn">
                                <img src="/assets/icons/linkedin.svg" alt="LinkedIn" class="w-5 h-5 transition-colors filter invert-[32%] sepia-[10%] saturate-[1210%] hue-rotate-[175deg] brightness-[97%] contrast-[87%]">
                            </a>
                        )}
                    </div>
                </div>
            </div>

            <div id="profile-bio" class="text-[1.05rem] text-text-secondary flex flex-col gap-5 mt-6">
                {data.profile.bio.map(paragraph => (
                    <p class="leading-relaxed font-body" set:html={parseMarkdown(paragraph)}></p>
                ))}
            </div>
            
            {data.profile.resume && (
                <a id="profile-resume" href={data.profile.resume} target="_blank" rel="noopener noreferrer" class="inline-block mt-6 text-[1.05rem] text-text-secondary hover:text-primary transition-colors duration-300 font-medium underline underline-offset-4">
                    View Resume
                </a>
            )}
        </section>

        <!-- Divider Line -->
        <hr class="border-t border-border-color my-9 max-w-[860px] mx-auto">

        <!-- Skills Section -->
        <section id="skills" class="py-4">
            <h2 class="font-heading text-2xl font-bold mb-8 text-text-primary">Skills</h2>
            <div id="skills-container" class="flex flex-col gap-5">
                {data.skills.map(skillGroup => (
                    <div class="skills-category-row flex items-start gap-8 mb-5 last:mb-0 max-[640px]:flex-col max-[640px]:gap-1.5 max-[640px]:mb-6">
                        <div class="skills-category-label font-mono text-[0.8rem] font-semibold text-text-muted tracking-[1.5px] uppercase w-[150px] shrink-0 pt-[0.2rem] max-[640px]:w-auto max-[640px]:pt-0">
                            {skillGroup.category}
                        </div>
                        <div class="skills-category-list font-body text-[1.05rem] font-normal text-text-primary leading-[1.6] tracking-[0.2px]">
                            {skillGroup.list.join(', ')}
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Divider Line -->
        <hr class="border-t border-border-color my-9 max-w-[860px] mx-auto">

        <!-- Projects Section -->
        <section id="projects" class="py-2">
            <h2 class="font-heading text-2xl font-bold mb-8 text-text-primary">Projects</h2>
            <div class="projects-grid grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                {data.projects.map(project => (
                    <article class="project-card bg-white border border-border-color rounded-md overflow-hidden shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary flex flex-col">
                        <div class="project-details p-7 flex flex-col flex-grow">
                            <div class="project-header flex justify-between items-start gap-4 mb-3">
                                <h3 class="project-title font-heading text-[1.35rem] font-bold mb-0 text-text-primary">
                                    {project.title}
                                </h3>
                                {project.codeUrl && (
                                    <a href={project.codeUrl} class="project-code-link inline-flex items-center justify-center transition-all duration-300 hover:scale-110 p-0.5 mt-0.5" target="_blank" rel="noopener noreferrer" aria-label={`View code repository for ${project.title}`}>
                                        <img src="/assets/icons/github.svg" alt="GitHub" class="project-code-icon w-5 h-5 transition-colors filter invert-[49%] sepia-[9%] saturate-[1018%] hue-rotate-[176deg] brightness-[93%] contrast-[89%]">
                                    </a>
                                )}
                            </div>
                            <div class="project-comment font-mono text-[0.8rem] text-text-muted mb-3">
                                {project.comment}
                            </div>
                            <p class="project-description text-[0.925rem] text-text-secondary mb-5 flex-grow">
                                {project.description}
                            </p>
                            <div class="project-tags flex flex-wrap gap-[0.45rem] mt-auto">
                                {project.tags.map(tag => (
                                    <span class="px-2.5 py-1 text-xs font-medium rounded-full bg-bg-secondary text-text-secondary border border-border-color">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>
    </main>
</Layout>
