---
import Layout from '../layouts/Layout.astro';
import { client } from '../sanity/client';

const posts = await client.fetch(`*[_type == "post"] | order(publishedAt desc)`) || [];
const profile = await client.fetch(`*[_type == "profile"][0]{ brandName, blogSubtitle }`);
const brandName = profile?.brandName || 'Blog';
const blogSubtitle = profile?.blogSubtitle || '';

function formatDate(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout title={`Blog - ${brandName}`} description={blogSubtitle}>
    <main class="max-w-[880px] mx-auto px-6 py-12 md:py-16">
        <!-- Blog Header -->
        <section class="mb-12">
            <h1 class="font-heading text-4xl md:text-5xl font-extrabold tracking-tight mb-4 text-text-primary">Blog</h1>
            {blogSubtitle && (
                <p class="text-[1.05rem] text-text-secondary max-w-[600px] leading-relaxed">
                    {blogSubtitle}
                </p>
            )}
        </section>

        <!-- Blog Posts List -->
        {posts.length > 0 ? (
            <section class="flex flex-col gap-10">
                {posts.map(post => (
                    <article class="flex flex-col gap-2 group">
                        <div class="flex items-center gap-3 text-sm text-text-muted font-mono">
                            <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                        </div>
                        <h2 class="font-heading text-2xl font-bold text-text-primary group-hover:text-primary transition-colors duration-300">
                            <a href={`/blog/${post.slug.current}`}>{post.title}</a>
                        </h2>
                        {post.description && (
                            <p class="text-[0.95rem] text-text-secondary leading-relaxed max-w-[720px]">
                                {post.description}
                            </p>
                        )}
                        <a href={`/blog/${post.slug.current}`} class="text-sm font-medium text-primary hover:underline mt-1">
                            Read article &rarr;
                        </a>
                    </article>
                ))}
            </section>
        ) : (
            <section class="flex flex-col items-center justify-center border border-dashed border-border-color rounded-md py-20 px-6 bg-bg-secondary/30 text-center">
                <div class="w-16 h-16 rounded-full bg-bg-secondary flex items-center justify-center border border-border-color mb-5">
                    <svg class="w-7 h-7 text-text-muted" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125"></path>
                    </svg>
                </div>
                <h2 class="font-heading text-xl font-bold text-text-primary mb-2">No Articles Yet</h2>
                <p class="text-[0.95rem] text-text-secondary max-w-[360px] leading-relaxed">
                    Writing is currently in progress. Subscribe or check back soon for my first post!
                </p>
            </section>
        )}
    </main>
</Layout>
