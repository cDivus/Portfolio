---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../input.css';
import { client } from '../sanity/client';
import { urlFor } from '../sanity/urlFor';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Fetch profile to get the favicon
const profile = await client.fetch(`*[_type == "profile"][0]{ favicon }`);
const faviconUrl = profile?.favicon ? urlFor(profile.favicon).url() : '';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth scroll-pt-[90px]">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{title}</title>
    <link rel="icon" type="image/png" href={faviconUrl}>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Vercel Web Analytics -->
    <script is:inline>
        window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
    </script>
    <script defer src="/_vercel/insights/script.js"></script>
</head>
<body class="bg-white text-text-primary font-body antialiased overflow-x-hidden">
    <Header />
    <slot />
    <Footer />
</body>
</html>
