---
import { client } from '../sanity/client';

const profile = await client.fetch(`*[_type == "profile"][0]{ brandName }`);
const brandName = profile?.brandName || '';
---
<footer class="border-t border-border-color bg-bg-secondary mt-16 transition-all duration-300">
    <div class="max-w-[880px] mx-auto px-6 py-8 flex justify-center items-center text-center text-text-secondary">
        <p>&copy; {new Date().getFullYear()} {brandName}. All rights reserved.</p>
    </div>
</footer>
